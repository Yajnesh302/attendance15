<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site.master.cs" Inherits="AttendanceApp.SiteMaster" %>

<!DOCTYPE html>
<html lang="en">
<head runat="server">
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title><asp:ContentPlaceHolder ID="TitleContent" runat="server"></asp:ContentPlaceHolder> - Attendance System</title>
    
    <!-- Custom fonts for this template-->
    <link href="Static/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
    <!-- Custom styles for this template-->
    <link href="Static/css/sb-admin-2.min.css" rel="stylesheet" />
    <link href="Static/css/dark-theme.css?v=1.4.0" rel="stylesheet" />

    <style>
        /* Tour Spotlight Spotlight styles */
        .tour-active {
            position: relative !important;
            z-index: 1000001 !important;
            box-shadow: 0 0 0 9999px rgba(15, 23, 42, 0.65), 0 12px 30px rgba(79, 70, 229, 0.25) !important;
            outline: 3px solid #4f46e5 !important;
            outline-offset: 4px !important;
            pointer-events: none !important;
            transition: box-shadow 0.25s ease-out, outline 0.25s ease-out !important;
        }

        body { color: #111 !important; }
        
        /* Premium Page Headings Redesign */
        h2 {
            font-size: 1.625rem !important;
            font-weight: 800 !important;
            color: #0f172a !important; /* Slate 900 */
            letter-spacing: -0.025em !important;
            border-left: 5px solid #4f46e5 !important; /* Indigo accent border */
            padding-left: 14px !important;
            margin-top: 0 !important;
            margin-bottom: 0 !important;
            line-height: 1.25 !important;
            display: inline-flex !important;
            align-items: center !important;
        }

        .sticky-top {
            position: -webkit-sticky !important;
            position: sticky !important;
            top: 0 !important;
            z-index: 1030 !important;
        }
        /* Sticky Top Nav for pages without sidebar */
        body.sticky-nav-page .navbar-custom {
            position: fixed !important;
            top: 0 !important;
            right: 0 !important;
            left: 0 !important;
            z-index: 1030 !important;
        }
        body.sticky-nav-page .container-main {
            margin-top: 60px !important; /* Offset by navbar height */
        }
        .navbar-custom {
            background-color: #4f46e5;
            background-image: linear-gradient(180deg,#4f46e5 10%,#3730a3 100%);
            padding: 0;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            height: 60px;
        }
        .navbar-custom .navbar-brand {
            color: white;
            font-weight: bold;
            padding: 15px 20px;
            font-size: 1.25rem;
        }
        .btn-logout {
            background-color: #e74a3b;
            color: white;
            border: none;
            padding: 6px 15px;
            border-radius: 4px;
            font-size: 0.85rem;
            font-weight: bold;
        }
        .btn-logout:hover {
            background-color: #c0392b;
            color: white;
        }
        .container-main {
            padding: 20px;
            background-color: #f8f9fc;
            min-height: calc(100vh - 60px);
        }
        .app-sidebar {
            width: 240px;
            background: linear-gradient(180deg, #1a237e 0%, #283593 60%, #1565c0 100%);
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            box-shadow: 2px 0 8px rgba(0,0,0,0.2);
            min-height: 100vh;
        }
        .sidebar-profile {
            padding: 20px 16px 16px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.15);
        }
        .sidebar-avatar {
            width: 140px;
            height: 180px;
            border-radius: 6px;
            border: 3px solid rgba(255,255,255,0.45);
            object-fit: cover;
            margin-bottom: 12px;
        }
        .sidebar-name {
            color: #fff;
            font-size: 0.9rem;
            font-weight: 700;
            line-height: 1.4;
        }
        .sidebar-role-badge {
            display: inline-block;
            margin-top: 10px;
            background: rgba(255,255,255,0.15);
            color: #a5d6a7;
            font-size: 0.72rem;
            font-weight: 700;
            padding: 3px 12px;
            border-radius: 20px;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }
        .header-nav-links .nav-link {
            padding: 6px 12px !important;
            font-size: 0.85rem;
            border-radius: 4px;
            transition: background-color 0.2s, color 0.2s;
            opacity: 0.85;
        }
        .header-nav-links .nav-link:hover {
            background-color: rgba(255, 255, 255, 0.15);
            color: #fff !important;
            opacity: 1;
        }

        /* ── Notification Bell ── */
        .notif-bell-wrap {
            position: relative;
            display: inline-flex;
            align-items: center;
            margin-right: 14px;
        }
        .notif-bell-btn {
            background: rgba(255,255,255,0.12);
            border: 1.5px solid rgba(255,255,255,0.22);
            color: white;
            width: 38px; height: 38px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer;
            font-size: 1rem;
            transition: background 0.2s, transform 0.2s;
            position: relative;
        }
        .notif-bell-btn:hover {
            background: rgba(255,255,255,0.25);
            transform: scale(1.08);
        }
        #notifBadge {
            position: absolute;
            top: -4px; right: -4px;
            background: #ef4444;
            color: white;
            font-size: 0.65rem;
            font-weight: 800;
            min-width: 18px; height: 18px;
            border-radius: 20px;
            display: flex; align-items: center; justify-content: center;
            padding: 0 4px;
            border: 2px solid #4f46e5;
            animation: pulse-badge 1.8s infinite;
        }
        @keyframes pulse-badge {
            0%, 100% { transform: scale(1); }
            50%       { transform: scale(1.18); }
        }
        .notif-dropdown {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 340px;
            background: rgba(255,255,255,0.97);
            backdrop-filter: blur(16px);
            border-radius: 14px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.18), 0 0 0 1px rgba(79,70,229,0.12);
            z-index: 99999;
            overflow: hidden;
            display: none;
            animation: dropIn 0.22s cubic-bezier(0.34,1.56,0.64,1);
        }
        .notif-dropdown.open { display: block; }
        @keyframes dropIn {
            from { opacity: 0; transform: translateY(-8px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }
        .notif-drop-header {
            background: linear-gradient(135deg,#4f46e5,#3730a3);
            color: white; padding: 12px 16px;
            display: flex; align-items: center; justify-content: space-between;
            font-weight: 700; font-size: 0.88rem;
        }
        .notif-drop-list { max-height: 280px; overflow-y: auto; }
        .notif-drop-item {
            padding: 11px 16px; border-bottom: 1px solid #f1f5f9;
            transition: background 0.15s; cursor: default;
        }
        .notif-drop-item:hover { background: #f8fafc; }
        .notif-drop-sender { font-weight: 700; color: #0f172a; font-size: 0.83rem; }
        .notif-drop-detail { color: #64748b; font-size: 0.78rem; margin-top: 2px; }
        .notif-drop-msg {
            color: #475569; font-size: 0.8rem; margin-top: 4px;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .notif-drop-footer {
            padding: 10px 16px; text-align: center;
            border-top: 1px solid #e2e8f0;
        }
        .notif-drop-footer a {
            color: #4f46e5; font-weight: 700; font-size: 0.85rem;
            text-decoration: none;
        }
        .notif-drop-footer a:hover { text-decoration: underline; }
        .notif-drop-empty { padding: 24px; text-align: center; color: #94a3b8; font-size: 0.88rem; }
        
        /* Global Elegant Toast Container at Top Right */
        #toast-container {
            position: fixed;
            top: 24px;
            right: 24px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            z-index: 200000 !important;
            pointer-events: none;
        }
        
        .modern-toast {
            display: flex;
            align-items: center;
            gap: 14px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(12px) saturate(180%);
            -webkit-backdrop-filter: blur(12px) saturate(180%);
            border-radius: 12px;
            padding: 14px 20px;
            min-width: 320px;
            max-width: 420px;
            color: #1e293b;
            font-size: 0.92rem;
            font-weight: 600;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04), inset 0 0 0 1px rgba(255, 255, 255, 0.5);
            transform: translateX(120%);
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
            opacity: 0;
            pointer-events: auto;
            border-left: 6px solid #64748b;
        }
        
        .modern-toast.toast-show {
            transform: translateX(0);
            opacity: 1;
        }
        
        .modern-toast.toast-hide {
            transform: translateY(-20px) scale(0.9);
            opacity: 0;
        }
        
        .toast-icon {
            font-size: 1.35rem;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        /* Toast Alert States with Curated Color Accents */
        .toast-success {
            border-left-color: #10b981;
            background: rgba(240, 253, 250, 0.95);
        }
        .toast-success .toast-icon {
            color: #10b981;
        }
        
        .toast-error {
            border-left-color: #ef4444;
            background: rgba(254, 242, 242, 0.95);
        }
        .toast-error .toast-icon {
            color: #ef4444;
        }
        
        .toast-warning {
            border-left-color: #f59e0b;
            background: rgba(255, 251, 235, 0.95);
        }
        .toast-warning .toast-icon {
            color: #f59e0b;
        }
        
        .toast-info {
            border-left-color: #3b82f6;
            background: rgba(239, 246, 255, 0.95);
        }
        .toast-info .toast-icon {
            color: #3b82f6;
        }
        
        .toast-close-btn {
            background: transparent;
            border: none;
            color: #94a3b8;
            cursor: pointer;
            font-size: 1.2rem;
            padding: 2px;
            line-height: 1;
            transition: color 0.15s ease;
            margin-left: auto;
        }
        .toast-close-btn:hover {
            color: #475569;
        }
    </style>
    <script>
        // FOUC Prevention: Apply theme class before paint (Light mode by default)
        (function(){
            var t = localStorage.getItem('app-theme');
            if (t === 'dark') document.documentElement.classList.add('theme-dark');
            else document.documentElement.classList.add('theme-light');
        })();
    </script>
    <script>
        // Global Upgraded Toast Notification System
        function showToast(msg, type = 'info') {
            let container = document.getElementById("toast-container");
            if (!container) {
                container = document.createElement("div");
                container.id = "toast-container";
                document.body.appendChild(container);
            }

            const toast = document.createElement("div");
            toast.className = `modern-toast toast-${type}`;
            
            let iconClass = "fas fa-info-circle";
            if (type === "success") iconClass = "fas fa-check-circle";
            else if (type === "warning") iconClass = "fas fa-exclamation-triangle";
            else if (type === "error") iconClass = "fas fa-times-circle";

            toast.innerHTML = `
                <div class="toast-icon"><i class="${iconClass}"></i></div>
                <div style="flex-grow: 1; padding-right: 8px;">${msg}</div>
                <button type="button" class="toast-close-btn" onclick="this.parentElement.classList.remove('toast-show'); setTimeout(() => this.parentElement.remove(), 400);">&times;</button>
            `;

            container.appendChild(toast);
            
            // Trigger reflow to run transition
            toast.offsetHeight;
            toast.classList.add("toast-show");

            // Auto dismiss
            setTimeout(() => {
                if (toast.parentElement) {
                    toast.classList.remove("toast-show");
                    toast.classList.add("toast-hide");
                    setTimeout(() => {
                        toast.remove();
                    }, 400);
                }
            }, 4000);
        }
    </script>
    <asp:ContentPlaceHolder ID="HeadContent" runat="server"></asp:ContentPlaceHolder>
</head>
<%
    string bodyClass = "";
    string rawUrl = Request.RawUrl.ToLower();
    if (rawUrl.Contains("attendance.aspx")) {
        bodyClass = "attendance-page";
    } else if (rawUrl.Contains("dashboard.aspx") || rawUrl.Contains("dashboard")) {
        bodyClass = "dashboard-page";
    } else {
        bodyClass = "sticky-nav-page";
    }
%>
<body id="page-top" class="<%= bodyClass %>">
    <form id="form1" runat="server" enctype="multipart/form-data">
        <div id="wrapper" class="d-flex">
            <!-- Sidebar -->
            <asp:PlaceHolder ID="phSidebar" runat="server">
                <div class="app-sidebar bg-gradient-primary sidebar-dark">
                    <!-- Profile block -->
                    <div class="sidebar-profile">
                        <div class="sidebar-logo-container" style="text-align: center; margin-bottom: 16px; padding: 0 8px;">
                            <div style="background: white; border-radius: 8px; padding: 8px 12px; display: inline-block; box-shadow: 0 4px 10px rgba(0,0,0,0.15);">
                                <img src="Static/Images/newlrdelogo.png" alt="LRDE Logo" style="max-width: 110px; height: auto; display: block; margin: 0 auto;" />
                            </div>
                        </div>
                        <hr style="border-top: 1px solid rgba(255, 255, 255, 0.18); margin: 12px 0 16px; width: 100%;" />
                        <img src="http://windflower.lrde.com/empphotos/Dsc_<%=Session["PCNO"]%>.jpg"
                              id="imgavtr" class="sidebar-avatar" alt="Avatar"
                              onerror="this.onerror=null; this.src='Static/Images/default_avatar.png';" />
                        <div class="sidebar-name">
                            <%=Session["Name"] != null ? Session["Name"].ToString() : "User" %>
                        </div>
                        <% if (Session["Designation"] != null && !string.IsNullOrEmpty(Session["Designation"].ToString())) { %>
                        <div class="sidebar-designation" style="font-size: 0.8rem; color: #cbd5e1; margin-top: 2px; margin-bottom: 8px; font-weight: 500; text-align: center;">
                            <%=Session["Designation"].ToString() %>
                        </div>
                        <% } %>
                        <span class="sidebar-role-badge">
                            <i id="myfw" runat="server" class="fas fa-user"></i>&nbsp;<label runat="server" id="lblUserName"></label>
                        </span>
                    </div>
                </div>
            </asp:PlaceHolder>

            <!-- Content Wrapper -->
            <div id="content-wrapper" class="d-flex flex-column flex-grow-1">
                <!-- Main Content -->
                <div id="content">
                    <!-- Topbar -->
                    <nav class="navbar navbar-expand navbar-light topbar <%= Request.RawUrl.ToLower().Contains("attendance.aspx") ? "static-top" : "sticky-top" %> navbar-custom">
                        <span class="navbar-brand text-white ml-3 font-weight-bold">
                            <i class="fas fa-building mr-2"></i> HR System
                        </span>

                        <!-- Top Navigation Links (visible only on non-dashboard pages) -->
                        <asp:PlaceHolder ID="phTopNav" runat="server">
                            <ul class="navbar-nav mr-auto ml-4 align-items-center header-nav-links">
                                <li class="nav-item">
                                    <a class="nav-link text-white font-weight-bold" href="Dashboard.aspx"><i class="fas fa-tachometer-alt mr-1"></i> Dashboard</a>
                                </li>
                                <asp:PlaceHolder ID="phEmployeeMaster" runat="server">
                                    <li class="nav-item ml-3">
                                        <a class="nav-link text-white font-weight-bold" href="Employee.aspx"><i class="fas fa-users mr-1"></i> Employee Master</a>
                                    </li>
                                </asp:PlaceHolder>
                                <asp:PlaceHolder ID="phVendors" runat="server">
                                    <li class="nav-item ml-3">
                                        <a class="nav-link text-white font-weight-bold" href="Vendors.aspx"><i class="fas fa-handshake mr-1"></i> Vendors</a>
                                    </li>
                                </asp:PlaceHolder>
                                <asp:PlaceHolder ID="phContracts" runat="server">
                                    <li class="nav-item ml-3">
                                        <a class="nav-link text-white font-weight-bold" href="Contracts.aspx"><i class="fas fa-file-signature mr-1"></i> Contracts</a>
                                    </li>
                                </asp:PlaceHolder>
                                <li class="nav-item ml-3">
                                    <a class="nav-link text-white font-weight-bold" href="Attendance.aspx"><i class="fas fa-calendar-check mr-1"></i> Attendance</a>
                                </li>
                                <li class="nav-item ml-3">
                                    <a class="nav-link text-white font-weight-bold" href="Ledger.aspx"><i class="fas fa-book mr-1"></i> Ledger</a>
                                </li>
                                <asp:PlaceHolder ID="phCalculation" runat="server">
                                    <li class="nav-item ml-3">
                                        <a class="nav-link text-white font-weight-bold" href="Calculation.aspx"><i class="fas fa-calculator mr-1"></i> Calculation</a>
                                    </li>
                                </asp:PlaceHolder>
                                <% if (Convert.ToInt32(Session["Role"] ?? 0) == 1) { %>
                                <li class="nav-item ml-3">
                                    <a class="nav-link text-white font-weight-bold" href="Remarks.aspx"><i class="fas fa-inbox mr-1"></i> Remarks</a>
                                </li>
                                <li class="nav-item ml-3">
                                    <a class="nav-link text-white font-weight-bold" href="Documents.aspx"><i class="fas fa-file-alt mr-1"></i> Documents</a>
                                </li>
                                <% } %>
                            </ul>
                        </asp:PlaceHolder>

                        <!-- Topbar User Information -->
                        <ul class="navbar-nav ml-auto align-items-center">
                            <% if (Request.Url.AbsolutePath.IndexOf("Dashboard.aspx", StringComparison.OrdinalIgnoreCase) >= 0) { %>
                            <li class="nav-item mr-2">
                                <button type="button" id="startTourBtn" class="theme-toggle-btn" onclick="triggerSiteTour()" title="Start Interactive Welcome Tour">
                                    <i class="fas fa-question-circle"></i>
                                </button>
                            </li>
                            <% } %>
                            <li class="nav-item">
                                <button type="button" id="themeToggleBtn" class="theme-toggle-btn" onclick="toggleAppTheme()" title="Toggle Dark/Light Mode">
                                    <i class="fas fa-moon" id="themeIcon"></i>
                                </button>
                            </li>
                            <li class="nav-item mr-3">
                                <span class="text-white font-weight-bold">Welcome, <%=Session["Name"] %><%= Session["Designation"] != null && !string.IsNullOrEmpty(Session["Designation"].ToString()) ? " (" + Session["Designation"].ToString() + ")" : "" %></span>
                            </li>
                            <%-- Notification bell (admin only) --%>
                            <% if (Convert.ToInt32(Session["Role"] ?? 0) == 1) { %>
                            <li class="nav-item">
                                <div class="notif-bell-wrap">
                                    <button type="button" class="notif-bell-btn" id="notifBellBtn" onclick="toggleNotifDrop(event)" title="Remarks Notifications">
                                        <i class="fas fa-bell"></i>
                                        <span id="notifBadge" style="<%= UnreadCount > 0 ? "" : "display:none;" %>"><%= UnreadCount %></span>
                                    </button>
                                    <div class="notif-dropdown" id="notifDropdown">
                                        <div class="notif-drop-header">
                                            <span><i class="fas fa-inbox mr-2"></i>Remarks Inbox</span>
                                            <span id="notifUnreadLabel"><%= UnreadCount %> unread</span>
                                        </div>
                                        <div class="notif-drop-list" id="notifDropList">
                                            <div class="notif-drop-empty"><i class="fas fa-spinner fa-spin"></i> Loading…</div>
                                        </div>
                                        <div class="notif-drop-footer">
                                            <a href="Remarks.aspx"><i class="fas fa-external-link-alt mr-1"></i>View all in Remarks Inbox</a>
                                        </div>
                                    </div>
                                </div>
                            </li>
                            <% } %>
                            <li class="nav-item">
                                <asp:Button ID="btnLogout" runat="server" Text="Logout" CssClass="btn-logout" OnClick="btnLogout_Click" OnClientClick="var _t=localStorage.getItem('app-theme'); localStorage.clear(); if(_t) localStorage.setItem('app-theme',_t); sessionStorage.clear();" CausesValidation="false" style="border-radius: 6px; font-weight: bold; margin-right: 15px;" />
                            </li>
                        </ul>
                    </nav>
                    <!-- End of Topbar -->

                    <!-- Begin Page Content -->
                    <div class="container-main">
                        <asp:ContentPlaceHolder ID="MainContent" runat="server"></asp:ContentPlaceHolder>
                    </div>
                </div>
                <!-- End of Main Content -->
            </div>
        </div>

        <!-- Bootstrap core JavaScript-->
        <script src="Static/jquery/jquery.min.js"></script>
        <script src="Static/bootstrap/js/bootstrap.bundle.min.js"></script>
        <!-- Core plugin JavaScript-->
        <script src="Static/jquery-easing/jquery.easing.min.js"></script>
        <!-- Custom scripts for all pages-->
        <script src="Static/js/sb-admin-2.min.js"></script>
        <script src="Static/js/sweetalert2@11.js"></script>
        <% if (Convert.ToInt32(Session["Role"] ?? 0) == 1) { %>
        <script>
            (function () {
                var dropLoaded = false;

                window.toggleNotifDrop = function (e) {
                    e.stopPropagation();
                    var drop = document.getElementById('notifDropdown');
                    if (!drop) return;
                    var isOpen = drop.classList.contains('open');
                    if (isOpen) {
                        drop.classList.remove('open');
                    } else {
                        drop.classList.add('open');
                        if (!dropLoaded) { loadNotifDrop(); dropLoaded = true; }
                    }
                };

                document.addEventListener('click', function (e) {
                    var wrap = document.getElementById('notifBellBtn');
                    var drop = document.getElementById('notifDropdown');
                    if (drop && drop.classList.contains('open')) {
                        if (!drop.contains(e.target) && e.target !== wrap && !wrap.contains(e.target)) {
                            drop.classList.remove('open');
                        }
                    }
                });

                function loadNotifDrop() {
                    fetch('Remarks.aspx/GetAllRemarks', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: '{}'
                    })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        var all = JSON.parse(data.d);
                        var unread = all.filter(function (r) { return !r.IsRead; });
                        var listEl = document.getElementById('notifDropList');
                        var badge  = document.getElementById('notifBadge');
                        var label  = document.getElementById('notifUnreadLabel');

                        if (badge)  { badge.textContent = unread.length; badge.style.display = unread.length > 0 ? 'flex' : 'none'; }
                        if (label)  { label.textContent = unread.length + ' unread'; }

                        var preview = unread.slice(0, 5);
                        if (preview.length === 0) {
                            listEl.innerHTML = '<div class="notif-drop-empty"><i class="fas fa-check-circle" style="color:#10b981;"></i> No unread remarks</div>';
                        } else {
                            listEl.innerHTML = preview.map(function (r) {
                                return '<div class="notif-drop-item">'
                                    + '<div class="notif-drop-sender"><i class="fas fa-user mr-1" style="color:#4f46e5;"></i>' + esc(r.SenderName) + '</div>'
                                    + '<div class="notif-drop-detail">Re: ' + esc(r.EmpName) + ' &bull; ' + esc(r.RemarkDateStr) + '</div>'
                                    + '<div class="notif-drop-msg">' + esc(r.Message) + '</div>'
                                    + '</div>';
                            }).join('');
                        }
                    })
                    .catch(function () {
                        var listEl = document.getElementById('notifDropList');
                        if (listEl) listEl.innerHTML = '<div class="notif-drop-empty">Failed to load.</div>';
                    });
                }

                function esc(s) {
                    if (!s) return '';
                    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
                }
            })();
        </script>
        <% } %>
        <script>
            // Theme Toggle Function
            function toggleAppTheme() {
                var html = document.documentElement;
                var icon = document.getElementById('themeIcon');
                if (html.classList.contains('theme-dark')) {
                    html.classList.remove('theme-dark');
                    html.classList.add('theme-light');
                    localStorage.setItem('app-theme', 'light');
                    if (icon) { icon.className = 'fas fa-moon'; }
                } else {
                    html.classList.remove('theme-light');
                    html.classList.add('theme-dark');
                    localStorage.setItem('app-theme', 'dark');
                    if (icon) { icon.className = 'fas fa-sun'; }
                }
            }
            // Set correct icon on page load
            (function() {
                var icon = document.getElementById('themeIcon');
                if (icon) {
                    if (document.documentElement.classList.contains('theme-dark')) {
                        icon.className = 'fas fa-sun';
                    } else {
                        icon.className = 'fas fa-moon';
                    }
                }
            })();

            // Interactive Welcome Tour System
            function triggerSiteTour() {
                if (window.location.pathname.indexOf('Dashboard.aspx') === -1) {
                    window.location.href = 'Dashboard.aspx?startTour=true';
                } else {
                    startWelcomeTour();
                }
            }

            var currentTourStep = 0;
            var activeSteps = [];

            function startWelcomeTour() {
                endTour();

                var tourSteps = [
                    {
                        selector: 'h2',
                        title: "Welcome to the App!",
                        text: "This is your primary dashboard. Let's do a quick walk-through of the main tools available."
                    },
                    {
                        selector: 'a[href="Employee.aspx"]',
                        title: "Employee Profiles",
                        text: "Configure contract worker information, assign categories, and view worker records here."
                    },
                    {
                        selector: 'a[href="Attendance.aspx"]',
                        title: "Mark Daily Attendance",
                        text: "Fill out monthly attendance grids, mark paid/unpaid leaves, and manage Saturday rules."
                    },
                    {
                        selector: 'a[href="Ledger.aspx"]',
                        title: "Leave Ledgers",
                        text: "Review detailed leave ledgers and historical balances for each worker in compliance with guidelines."
                    },
                    {
                        selector: 'a[href="Calculation.aspx"]',
                        title: "Wage Calculation Grid",
                        text: "Compute monthly employee basic wages, ESI, EPF capped distributions, service charges, and GST."
                    },
                    {
                        selector: 'a[href="Documents.aspx"]',
                        title: "Document & Templates Hub",
                        text: "Manage global template structures, print covering letters, and export wages calculations."
                    },
                    {
                        selector: 'a[href="AdminManagement.aspx"]',
                        title: "Admin Management",
                        text: "Assign administrator roles, manage system access, and configure division checklists for users."
                    },
                    {
                        selector: 'a[href="Settings.aspx"]',
                        title: "System Settings",
                        text: "Configure master divisions, departments, categories, and core administrative definitions."
                    },
                    {
                        selector: 'a[href="Vendors.aspx"]',
                        title: "Vendors & Agencies",
                        text: "Onboard and manage vendor companies, agencies, and overall supplier contracts."
                    },
                    {
                        selector: 'a[href="Contracts.aspx"]',
                        title: "Contracts Settings",
                        text: "Configure active contract agreements, vendor details, and order reference numbers."
                    },
                    {
                        selector: 'a[href="Remarks.aspx"]',
                        title: "Remarks Inbox",
                        text: "Review and approve leave, correction, and attendance remarks submitted by contract workers."
                    },
                    {
                        selector: 'a[href="UserRemarks.aspx"]',
                        title: "My Attendance Remarks",
                        text: "Send remarks and request corrections for attendance logs directly to administrators."
                    },
                    {
                        selector: '#themeToggleBtn',
                        title: "Light & Dark Mode Toggle",
                        text: "Click this sun/moon button to switch instantly between light and dark modes at any time."
                    }
                ];

                activeSteps = tourSteps.filter(function(step) {
                    var el = document.querySelector(step.selector);
                    return el && (el.offsetWidth > 0 || el.offsetHeight > 0);
                });

                if (activeSteps.length === 0) return;

                currentTourStep = 0;
                renderTourStep();
            }

            function renderTourStep() {
                var prevHighlight = document.querySelector('.tour-active');
                if (prevHighlight) {
                    prevHighlight.classList.remove('tour-active');
                }

                if (currentTourStep < 0 || currentTourStep >= activeSteps.length) {
                    endTour();
                    return;
                }

                var step = activeSteps[currentTourStep];
                var targetEl = document.querySelector(step.selector);
                if (!targetEl) return;

                targetEl.classList.add('tour-active');
                targetEl.scrollIntoView({ behavior: 'smooth', block: 'center' });

                var tooltip = document.getElementById('tourTooltipPopover');
                if (!tooltip) {
                    tooltip = document.createElement('div');
                    tooltip.id = 'tourTooltipPopover';
                    tooltip.style.cssText = "position: absolute; display: none; background: var(--card-bg, white); color: var(--text-color, #1e293b); border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.25); padding: 18px; width: 310px; z-index: 1000002; border-top: 4px solid #4f46e5; transition: all 0.2s ease-out; box-sizing: border-box;";
                    document.body.appendChild(tooltip);
                }

                var closeHtml = '<span onclick="endTour()" onmouseover="this.style.color=\'#ef4444\'" onmouseout="this.style.color=\'#94a3b8\'" style="position: absolute; top: 12px; right: 12px; font-size: 0.85rem; color: #94a3b8; cursor: pointer; transition: color 0.15s;" title="Close Tour"><i class="fas fa-times"></i></span>';
                var titleHtml = '<h6 style="font-weight: 800; color: #4f46e5; margin: 0 0 8px 0; font-size: 1rem; display: flex; align-items: center; gap: 8px;"><i class="fas fa-magic"></i> ' + esc(step.title) + '</h6>';
                var textHtml = '<p style="color: var(--text-muted, #64748b); font-size: 0.85rem; line-height: 1.5; margin: 0 0 16px 0;">' + esc(step.text) + '</p>';
                var footerHtml = '<div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border-color, #e2e8f0); padding-top: 12px; margin-top: 4px;">' +
                    '<span style="font-size: 0.75rem; color: #94a3b8; font-weight: 600;">' + (currentTourStep + 1) + ' of ' + activeSteps.length + '</span>' +
                    '<div style="display: flex; gap: 8px;">' +
                    (currentTourStep > 0 ? '<button type="button" class="btn btn-sm btn-outline-secondary" onclick="prevTourStep()" style="padding: 3px 10px; font-size: 0.75rem; border-radius: 6px;">Back</button>' : '') +
                    '<button type="button" class="btn btn-sm btn-primary" onclick="nextTourStep()" style="padding: 3px 12px; font-size: 0.75rem; font-weight: 700; background-color: #4f46e5; border-color: #4f46e5; color: white; border-radius: 6px;">' + (currentTourStep === activeSteps.length - 1 ? 'Finish' : 'Next') + '</button>' +
                    '</div></div>';

                tooltip.innerHTML = closeHtml + titleHtml + textHtml + footerHtml;

                setTimeout(function() {
                    var rect = targetEl.getBoundingClientRect();
                    var scrollLeft = window.pageXOffset || document.documentElement.scrollLeft;
                    var scrollTop = window.pageYOffset || document.documentElement.scrollTop;

                    var top = rect.bottom + scrollTop + 12;
                    var left = rect.left + scrollLeft + (rect.width / 2) - 155;

                    if (left < 10) left = 10;
                    if (left + 310 > window.innerWidth) left = window.innerWidth - 320;
                    if (rect.bottom + 200 > window.innerHeight) {
                        top = rect.top + scrollTop - tooltip.offsetHeight - 12;
                    }

                    tooltip.style.top = top + 'px';
                    tooltip.style.left = left + 'px';
                    tooltip.style.display = 'block';
                }, 150);
            }

            function prevTourStep() {
                if (currentTourStep > 0) {
                    currentTourStep--;
                    renderTourStep();
                }
            }

            function nextTourStep() {
                if (currentTourStep < activeSteps.length - 1) {
                    currentTourStep++;
                    renderTourStep();
                } else {
                    endTour();
                }
            }

            function endTour() {
                var prevHighlight = document.querySelector('.tour-active');
                if (prevHighlight) {
                    prevHighlight.classList.remove('tour-active');
                }
                var tooltip = document.getElementById('tourTooltipPopover');
                if (tooltip) {
                    tooltip.style.display = 'none';
                }
            }

            function esc(s) {
                if (!s) return '';
                return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            }

            // Auto-trigger welcome tour on redirection check
            (function() {
                var urlParams = new URLSearchParams(window.location.search);
                if (urlParams.get('startTour') === 'true') {
                    var cleanUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
                    window.history.replaceState({ path: cleanUrl }, '', cleanUrl);
                    setTimeout(function() {
                        startWelcomeTour();
                    }, 500);
                }
            })();
        </script>
    </form>
</body>
</html>
